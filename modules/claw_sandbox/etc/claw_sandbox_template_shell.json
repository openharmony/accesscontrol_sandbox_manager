{
  "system-mounts": [
    {
      "source": "/proc",
      "target": "/proc",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/sys",
      "target": "/sys",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/dev",
      "target": "/dev",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/tmp",
      "target": "/tmp",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/sbin",
      "target": "/sbin",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/sys_prod",
      "target": "/sys_prod",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/system/fonts",
      "target": "/system/fonts",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/system/lib",
      "target": "/system/lib",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/system/usr",
      "target": "/system/usr",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/system/profile",
      "target": "/system/profile",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/system/bin",
      "target": "/system/bin",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/system/lib64",
      "target": "/system/lib64",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/system/etc",
      "target": "/system/etc",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/system/framework",
      "target": "/system/framework",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/system/resource",
      "target": "/system/resource",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/system/app/skills",
      "target": "/system/app/skills",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/vendor/lib",
      "target": "/vendor/lib",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/vendor/lib64",
      "target": "/vendor/lib64",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/config",
      "target": "/config",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    }
  ],
  "symbol-links": [
    {
      "source": "/system/bin",
      "target": "/bin"
    },
    {
      "source": "/system/lib",
      "target": "/lib"
    },
    {
      "source": "/system/lib64",
      "target": "/lib64"
    },
    {
      "source": "/system/etc",
      "target": "/etc"
    },
    {
      "source": "/system/usr",
      "target": "/usr"
    }
  ],
  "app-mounts": [
    {
      "source": "/data/app/el1/bundle/<currentUserId>/hnppublic",
      "target": "/data/service/hnp",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/data/app/el1/bundle/public/<PackageName>",
      "target": "/data/storage/el1/bundle",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    },
    {
      "source": "/data/app/el1/bundle/<currentUserId>/hnp/<PackageName>",
      "target": "/data/app/bin",
      "mount-flags": ["bind", "rec"],
      "check-exists": true
    }
  ],
  "env-policy": {
    "blocked-everywhere-keys": [],
    "blocked-override-only-keys": [],
    "allowed-inherited-override-only-keys": [],
    "blocked-prefixes": [],
    "blocked-override-prefixes": []
  },
  "permission": {
    "ohos.permission.READ_WRITE_DOWNLOAD_DIRECTORY":[{
      "sandbox-switch": "ON",
      "gids": [1006, 3076],
      "dec-paths": ["/storage/Users/currentUser/Download"]
    }],
    "ohos.permission.READ_WRITE_DESKTOP_DIRECTORY":[{
      "sandbox-switch": "ON",
      "gids": [1006, 3076],
      "dec-paths": ["/storage/Users/currentUser/Desktop"]
    }],
    "ohos.permission.READ_WRITE_DOCUMENTS_DIRECTORY":[{
      "sandbox-switch": "ON",
      "gids": [1006, 3076],
      "dec-paths": ["/storage/Users/currentUser/Documents"]
    }],
    "ohos.permission.FILE_ACCESS_MANAGER":[{
      "sandbox-switch": "ON",
      "gids": [1006, 3076],
      "dec-paths": ["/storage/Users/currentUser/Documents",
                    "/storage/Users/currentUser/Desktop",
                    "/storage/Users/currentUser/Download"
                  ]
    }],
    "ohos.permission.INTERNET":[{
      "sandbox-switch": "ON",
      "gids": [1097]
    }]
  },
  "conditional": [
    {
      "source": "/data/service/el2/<currentUserId>/hmdfs/account/files/Docs/Desktop",
      "target": "/storage/Users/currentUser/Desktop",
      "mount-flags": ["bind", "rec"],
      "check-exists": true,
      "permissions": ["ohos.permission.READ_WRITE_DESKTOP_DIRECTORY", "ohos.permission.FILE_ACCESS_MANAGER"]
    },
    {
      "source": "/data/service/el2/<currentUserId>/hmdfs/account/files/Docs/Download",
      "target": "/storage/Users/currentUser/Download",
      "mount-flags": ["bind", "rec"],
      "check-exists": true,
      "permissions": ["ohos.permission.READ_WRITE_DOWNLOAD_DIRECTORY", "ohos.permission.FILE_ACCESS_MANAGER"]
    },
    {
      "source": "/data/service/el2/<currentUserId>/hmdfs/account/files/Docs/Documents",
      "target": "/storage/Users/currentUser/Documents",
      "mount-flags": ["bind", "rec"],
      "check-exists": true,
      "permissions": ["ohos.permission.READ_WRITE_DOCUMENTS_DIRECTORY", "ohos.permission.FILE_ACCESS_MANAGER"]
    },
    {
      "source": "/data/service/el2/<currentUserId>/hmdfs/account/files/Docs",
      "target": "/storage/Users/currentUser",
      "mount-flags": ["bind", "rec"],
      "check-exists": true,
      "permissions": ["ohos.permission.FILE_ACCESS_MANAGER"]
    },
    {
      "source": "/data/app/el2/<currentUserId>/base/<PackageName>",
      "target": "/data/storage/el2/base",
      "mount-flags": ["bind", "rec"],
      "check-exists": true,
      "permissions": []
    }
  ]
}
